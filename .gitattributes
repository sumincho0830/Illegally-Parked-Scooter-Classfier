# Set line endings to LF for all text files
* text=auto

# Explicitly set line endings for known file types
*.kt        text eol=lf
*.xml       text eol=lf
*.kts       text eol=lf
*.pro       text eol=lf
*.json      text eol=lf
*.gradle    text eol=lf
*.toml      text eol=lf
*.properties text eol=lf

# Keep binary files untouched
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary

# Shell scripts and executables should use LF
*.sh        text eol=lf
*.bat       text eol=crlf

# Ensure Gradle wrapper files use LF
gradlew     text eol=lf
gradlew.bat text eol=crlf
